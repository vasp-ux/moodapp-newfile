# API Environment Template
# Copy this file to project root as `.env` and fill values.

# Preferred provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=MoodSense
USE_OPENROUTER=true

# Optional fallback provider
GEMINI_API_KEY=
USE_GEMINI=false

AI_MODE=false
API_PORT=8000
ADMIN_KEY=2005
ADMIN_EMAIL=admin@gmail.com

# RBAC / Security
RBAC_DB_URL=sqlite:///data/rbac.db
JWT_SECRET=change-me
JWT_EXPIRES_MIN=120
DATA_ENC_KEY=
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SYSTEM_LOCK_DEFAULT=false

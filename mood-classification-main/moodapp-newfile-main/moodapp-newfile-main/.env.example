# MoodSense environment template
# Copy this file to `.env` in the same folder and fill the secrets you need.

AI_MODE=true
API_PORT=8000

# Cloud providers
USE_OPENROUTER=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://127.0.0.1:8000
OPENROUTER_APP_NAME=MoodSense

USE_GEMINI=true
GEMINI_API_KEY=

# Local fallback provider
USE_OLLAMA=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Admin access
ADMIN_KEY=
ADMIN_EMAIL=

# RBAC / auth
JWT_SECRET=change-this-local-dev-secret
JWT_EXPIRES_MIN=120
DATA_ENC_KEY=replace-with-a-fernet-key
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SYSTEM_LOCK_DEFAULT=false

# Storage
# Leave these commented to use the defaults from code.
# RBAC_DB_URL=sqlite:///data/rbac.db
# MOODSENSE_DB_PATH=data/moodsense.db

# Visual tracking
VISUAL_TRACK_TTL_SECONDS=180
VISUAL_TEMPLATE_ALPHA=0.18
VISUAL_MATCH_THRESHOLD=0.82
FACE_PROFILE_MATCH_THRESHOLD=0.93
FACE_PROFILE_MAX_IMAGES=6
FACE_PROFILE_RECOMMENDED_IMAGES=3
